separator_block_width=10

[focused_window]
command=xdotool getwindowfocus getwindowname
interval=1
color=#ffb5d9
align=center
label= 
separator=false



[seperator]
label=
command=echo ""
interval=once

# [separator]
# command=echo " | "
# interval=once
# color=#ffb5d9



[time]
label= 
command=date '+%I:%M %p'
interval=60
color=#ffb5d9
separator=false
color=#eb4034


[date]
label=  
command=date '+%Y-%m-%d'
interval=3600
color=#ffb5d9
separator=false
color=#eb4034



[volume]
label= 
command=pamixer --get-volume
interval=1
color=#a2ffbc
separator=false



[battery]
label= 
command=acpi | awk -F', ' '{print $2}'
interval=30
color=##ffdca3
separator=false

[spacer]
label=
command=echo " "
interval=1


